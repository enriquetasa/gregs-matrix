# App runtime: restricted DB user (recommended on DigitalOcean).
DATABASE_URL="postgresql://APP_USER:PASSWORD@HOST:25060/DATABASE?sslmode=require"

# Migrations only: use doadmin (or other owner) so prisma can create objects in public.
# If unset, db:migrate / container startup falls back to DATABASE_URL (fine for local CI).
DATABASE_MIGRATE_URL="postgresql://doadmin:PASSWORD@HOST:25060/DATABASE?sslmode=require"

SESSION_SECRET="replace-with-random-string-at-least-32-chars"
